# Dependencies
node_modules/
frontend/node_modules/

# TypeScript build output
build/
frontend/dist/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage and test output
coverage/
.nyc_output/
test-results/
cypress/screenshots/
cypress/videos/

# Environment and secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Uploads (user-generated content)
uploads/complaints/

# SQLite database files
*.db
*.sqlite

# Compiled Angular output (redundant with frontend/dist/ but explicit)
frontend/dist/

# Angular cache
.angular/

# Grunt
.grunt/

# Package manager lock files (keep package-lock.json for reproducibility, but ignore yarn.lock if not used)
yarn.lock

# Misc build artifacts
*.js.map
_build_flag

# Snyk / security scan cache
.dccache

# Terraform state
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars

# Vagrant
vagrant/.vagrant/

# Monitoring / local config overrides
monitoring/grafana/data/
